    "custom_liquid_96xLW3": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap');\n\n  .jw {\n    background: #fff;\n    padding: 3.5rem 1.5rem 3rem;\n    font-family: 'Poppins', sans-serif;\n    width: 100%;\n  }\n\n  .jlabel {\n    font-size: 9px;\n    letter-spacing: .38em;\n    text-transform: uppercase;\n    color: #673C43;\n    text-align: center;\n    margin-bottom: .6rem;\n    opacity: 0;\n    animation: jfu .6s ease forwards .15s;\n  }\n\n  .jtitle {\n    font-size: clamp(1.4rem, 5vw, 2.3rem);\n    font-weight: 600;\n    color: #111;\n    text-align: center;\n    margin: 0 0 .3rem;\n    line-height: 1.2;\n    opacity: 0;\n    animation: jfu .7s ease forwards .3s;\n  }\n\n  .jtitle em {\n    color: #673C43;\n    font-style: italic;\n    font-weight: 300;\n  }\n\n  .jsub {\n    font-size: clamp(11px, 2.5vw, 12.5px);\n    font-weight: 300;\n    color: #555;\n    text-align: center;\n    margin: 0 0 2.8rem;\n    letter-spacing: .03em;\n    opacity: 0;\n    animation: jfu .7s ease forwards .45s;\n  }\n\n  .jgrid {\n    display: flex;\n    flex-direction: column;\n    max-width: 860px;\n    margin: 0 auto;\n  }\n\n  .jcard {\n    display: flex;\n    flex-direction: row;\n    align-items: flex-start;\n    gap: 1.2rem;\n    padding: 1.4rem 1rem;\n    position: relative;\n    opacity: 0;\n    transform: translateY(18px);\n    border-bottom: 1px solid rgba(103,60,67,.12);\n  }\n\n  .jcard:last-child { border-bottom: none; }\n  .jcard:nth-child(1) { animation: jfu .7s ease forwards .6s; }\n  .jcard:nth-child(2) { animation: jfu .7s ease forwards .8s; }\n  .jcard:nth-child(3) { animation: jfu .7s ease forwards 1s; }\n\n  .jring {\n    width: 72px;\n    height: 72px;\n    min-width: 72px;\n    border-radius: 50%;\n    border: 1px solid rgba(103,60,67,.25);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    position: relative;\n    transition: border-color .4s;\n  }\n\n  .jring:hover { border-color: rgba(103,60,67,.65); }\n  .jring:hover .jico { transform: scale(1.1); }\n  .jring:hover .jdot { animation-play-state: running; }\n\n  .jdot {\n    position: absolute;\n    width: 4px;\n    height: 4px;\n    border-radius: 50%;\n    top: 50%;\n    left: 50%;\n    transform-origin: 0 0;\n    animation: jorbit-sm 3.5s linear infinite paused;\n    opacity: .75;\n    background: #673C43;\n  }\n\n  .jcard:nth-child(2) .jdot { animation-duration: 2.9s; background: #111; }\n  .jcard:nth-child(3) .jdot { animation-duration: 4.1s; }\n\n  @keyframes jorbit-sm {\n    from { transform: rotate(0deg) translateX(36px) rotate(0deg); }\n    to   { transform: rotate(360deg) translateX(36px) rotate(-360deg); }\n  }\n\n  .jib {\n    width: 50px;\n    height: 50px;\n    border-radius: 50%;\n    background: rgba(103,60,67,.07);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: background .4s;\n  }\n\n  .jring:hover .jib { background: rgba(103,60,67,.14); }\n\n  .jico {\n    width: 26px;\n    height: 26px;\n    transition: transform .3s;\n  }\n\n  .jtext {\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    padding-top: .1rem;\n  }\n\n  .jnum {\n    font-size: 8.5px;\n    font-weight: 500;\n    letter-spacing: .3em;\n    color: #673C43;\n    text-transform: uppercase;\n    margin-bottom: .3rem;\n  }\n\n  .jttl {\n    font-size: clamp(.95rem, 3vw, 1.05rem);\n    font-weight: 600;\n    color: #111;\n    margin: 0 0 .4rem;\n    line-height: 1.2;\n  }\n\n  .jdesc {\n    font-size: clamp(11px, 2.5vw, 12px);\n    font-weight: 300;\n    line-height: 1.8;\n    color: #555;\n  }\n\n  @keyframes jfu {\n    from { opacity: 0; transform: translateY(16px); }\n    to   { opacity: 1; transform: translateY(0); }\n  }\n\n  @keyframes jlr {\n    from { opacity: 0; transform: scaleX(0); }\n    to   { opacity: 1; transform: scaleX(1); }\n  }\n\n  @media (min-width: 640px) {\n    .jgrid {\n      flex-direction: row;\n      align-items: stretch;\n      position: relative;\n    }\n\n    .jgrid::before {\n      content: '';\n      position: absolute;\n      top: 48px;\n      left: calc(16.6% + 32px);\n      right: calc(16.6% + 32px);\n      height: 1px;\n      background: linear-gradient(90deg, rgba(103,60,67,.15), #673C43 50%, rgba(103,60,67,.15));\n      opacity: 0;\n      animation: jlr .9s ease forwards 1.2s;\n    }\n\n    .jcard {\n      flex: 1;\n      flex-direction: column;\n      align-items: center;\n      text-align: center;\n      gap: 0;\n      padding: 0 1rem 2rem;\n      border-bottom: none;\n      border-right: 1px solid rgba(103,60,67,.12);\n    }\n\n    .jcard:last-child { border-right: none; }\n\n    .jring {\n      width: 96px;\n      height: 96px;\n      min-width: 96px;\n      margin-bottom: 1.4rem;\n    }\n\n    .jib { width: 64px; height: 64px; }\n    .jico { width: 28px; height: 28px; }\n\n    .jdot {\n      width: 5px;\n      height: 5px;\n      animation-name: jorbit-lg;\n    }\n\n    .jtext { align-items: center; }\n    .jdesc { max-width: 190px; }\n  }\n\n  @keyframes jorbit-lg {\n    from { transform: rotate(0deg) translateX(48px) rotate(0deg); }\n    to   { transform: rotate(360deg) translateX(48px) rotate(-360deg); }\n  }\n</style>\n\n<div class=\"jw\">\n  <p class=\"jlabel\">How to use</p>\n  <h2 class=\"jtitle\">Flawless wings, <em>every time.</em></h2>\n  <p class=\"jsub\">Three effortless steps to your perfect liner look</p>\n\n  <div class=\"jgrid\">\n\n    <div class=\"jcard\">\n      <div class=\"jring\">\n        <div class=\"jdot\"></div>\n        <div class=\"jib\">\n          <svg class=\"jico\" viewBox=\"0 0 30 30\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <circle cx=\"15\" cy=\"10.5\" r=\"4.5\" stroke=\"#673C43\" stroke-width=\"1.2\"/>\n            <path d=\"M15 17c-4.5 0-8 1.8-8 4\" stroke=\"#673C43\" stroke-width=\"1.2\" stroke-linecap=\"round\"/>\n            <path d=\"M22 21l-3.5-3.5m3.5 0v3.5h-3.5\" stroke=\"#111\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            <circle cx=\"21\" cy=\"21\" r=\"3.2\" stroke=\"#111\" stroke-width=\"1\" stroke-dasharray=\"2 1.5\" opacity=\"0.4\"/>\n          </svg>\n        </div>\n      </div>\n      <div class=\"jtext\">\n        <p class=\"jnum\">Step 01</p>\n        <h3 class=\"jttl\">Position the stamp</h3>\n        <p class=\"jdesc\">Align the outer corner with your upper lash line, angling it toward the tail of your brow.</p>\n      </div>\n    </div>\n\n    <div class=\"jcard\">\n      <div class=\"jring\">\n        <div class=\"jdot\"></div>\n        <div class=\"jib\">\n          <svg class=\"jico\" viewBox=\"0 0 30 30\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M15 5.5v2M9.5 8l1.3 1.3M6 15h2M9.5 22l1.3-1.3\" stroke=\"#673C43\" stroke-width=\"1.1\" stroke-linecap=\"round\" opacity=\"0.4\"/>\n            <path d=\"M19 13.5c0-2.2-1.8-3.8-4-3.8s-4 1.6-4 3.8v4.8l1.4 1.4h5.2l1.4-1.4v-4.8z\" stroke=\"#673C43\" stroke-width=\"1.2\" stroke-linejoin=\"round\"/>\n            <path d=\"M13 18.3v2.8a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-2.8\" stroke=\"#111\" stroke-width=\"1.2\"/>\n            <path d=\"M13 14h4\" stroke=\"#111\" stroke-width=\"1\" stroke-linecap=\"round\" opacity=\"0.45\"/>\n          </svg>\n        </div>\n      </div>\n      <div class=\"jtext\">\n        <p class=\"jnum\">Step 02</p>\n        <h3 class=\"jttl\">Press &amp; release</h3>\n        <p class=\"jdesc\">Apply gentle, even pressure for 2–3 seconds. Lift cleanly — no rocking — to reveal a sharp wing.</p>\n      </div>\n    </div>\n\n    <div class=\"jcard\">\n      <div class=\"jring\">\n        <div class=\"jdot\"></div>\n        <div class=\"jib\">\n          <svg class=\"jico\" viewBox=\"0 0 30 30\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M6 17c3-1 5-3.5 9-3.5s6 2.5 9 3.5\" stroke=\"#673C43\" stroke-width=\"1.3\" stroke-linecap=\"round\"/>\n            <path d=\"M21 13.5l2.8 3.5-2.8 1\" stroke=\"#673C43\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            <path d=\"M9 20c1.5-.5 3-1.4 6-1.4s4.5.9 6 1.4\" stroke=\"#111\" stroke-width=\"1.1\" stroke-linecap=\"round\" opacity=\"0.45\"/>\n            <circle cx=\"15\" cy=\"13\" r=\"1.4\" fill=\"#673C43\" opacity=\"0.35\"/>\n            <path d=\"M12 24h6\" stroke=\"#111\" stroke-width=\"1.3\" stroke-linecap=\"round\"/>\n          </svg>\n        </div>\n      </div>\n      <div class=\"jtext\">\n        <p class=\"jnum\">Step 03</p>\n        <h3 class=\"jttl\">Connect the line</h3>\n        <p class=\"jdesc\">Use the pen tip to draw inward along the lash line. Symmetry perfected in seconds.</p>\n      </div>\n    </div>\n\n  </div>\n</div>",
